rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User progress media - photos and videos
    match /users/{userId}/progress-media/{mediaType}/{allPaths=**} {
      // Users can only access their own media
      allow read: if request.auth != null && request.auth.uid == userId;

      // Photos: max 10MB, only images
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && mediaType == 'photos'
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Videos: max 100MB, only videos
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && mediaType == 'videos'
                   && request.resource.size < 100 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }

    // User documents - training plans, diet plans, custom files
    match /users/{userId}/documents/{allPaths=**} {
      // Users can only access their own documents
      allow read: if request.auth != null && request.auth.uid == userId;

      // Documents: max 10MB, allowed types: PDF, DOC, DOCX, TXT, images
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType == 'application/pdf'
                       || request.resource.contentType == 'application/msword'
                       || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                       || request.resource.contentType == 'text/plain'
                       || request.resource.contentType.matches('image/.*'));
    }
  }
}
