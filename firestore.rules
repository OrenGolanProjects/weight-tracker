rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only access their own data
    // This includes profile data and calendar settings (with sensitive OAuth tokens)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Weight entries subcollection
      match /weightEntries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Body measurements subcollection
      match /bodyMeasurements/{measurementId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Progress media subcollection
      match /progressMedia/{mediaId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Documents subcollection (training plans, diet plans, custom files)
      match /documents/{documentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
