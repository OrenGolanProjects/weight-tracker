# Firebase Configuration for Production
# Copy this file to .env.production.local and fill in your Firebase project values

# Firebase Project Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: Firebase Measurement ID (for Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Notes:
# - All variables must be prefixed with NEXT_PUBLIC_ to be accessible in the browser
# - Get these values from Firebase Console > Project Settings > General
# - For production, create .env.production.local (gitignored)
# - For development, create .env.local (gitignored)
